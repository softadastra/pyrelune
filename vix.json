{
  "name": "pyrelune",
  "namespace": "softadastra",
  "version": "0.1.2",
  "type": "executable",
  "license": "MIT",
  "description": "A Python execution kernel for interactive notebooks in Vix Note",
  "repository": "https://github.com/softadastra/pyrelune",
  "keywords": [
    "vix",
    "vix-note",
    "python",
    "kernel",
    "notebook"
  ],
  "authors": [
    {
      "name": "Softadastra",
      "github": "softadastra"
    }
  ],
  "extensions": {
    "note": {
      "api": "1",
      "runtime": {
        "protocol": "vix-note-extension-1",
        "command": "pyrelune",
        "mode": "oneshot"
      },
      "cellTypes": [
        {
          "id": "python",
          "label": "Python",
          "language": "python",
          "executable": true,
          "aliases": [
            "py"
          ],
          "commentLine": "#",
          "defaultSource": "# Write your explanation here.\n",
          "placeholder": "Write your explanation here."
        }
      ],
      "capabilities": [
        "execute",
        "stdout",
        "stderr",
        "mime-output",
        "diagnostics"
      ],
      "icon": "assets/icon.svg"
    }
  }
}
